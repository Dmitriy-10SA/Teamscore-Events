<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<views xmlns="http://schemas.haulmont.com/cuba/view.xsd">
    <!-- View для сущности Event (какие атрибуты показывать в списке) -->
    <view entity="events_Event" name="event-browse" extends="_local">
        <property name="responsibleUser" view="_minimal"/>
        <property name="type" view="_minimal"/>
        <property name="createTs"/>
    </view>
    <!-- View для сущности Event (какие атрибуты показывать при редактировании) -->
    <view entity="events_Event" name="event-edit" extends="_local">
        <property name="responsibleUser" view="_minimal"/>
        <property name="type" view="_minimal">
            <property name="fields" view="_minimal"/>
        </property>
        <property name="fieldValues" view="_minimal">
            <property name="eventField" view="_minimal">
                <property name="eventType" view="_minimal"/>
            </property>
        </property>
    </view>
    <!-- View для сущности EventFieldValue со всеми полями значений -->
    <view entity="events_EventFieldValue" name="eventFieldValue-with-values" extends="_local">
        <property name="eventField" view="_minimal"/>
        <property name="event" view="_minimal"/>
        <property name="stringValue"/>
        <property name="textValue"/>
        <property name="dateValue"/>
        <property name="dateTimeValue"/>
        <property name="fileValue" view="_minimal"/>
    </view>
</views>